# Core Project Settings
PROJECT_NAME=SentinAI
ENVIRONMENT=development
API_V1_STR=/api/v1

# PostgreSQL Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sentinai_dev
POSTGRES_PORT=5432

# Vector DB (ChromaDB)
# Local path for vector storage
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=sentinai_compliance

# Cloud Storage (AWS S3 or equivalent for data lake/lineage)
CLOUD_STORAGE_BUCKET=sentinai-data-lake-dev
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# LLM / Agentic API Keys
OPENAI_API_KEY=your_openai_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
LANGCHAIN_API_KEY=your_langchain_api_key

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=sentinai

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Agent Orchestration
POSTGRES_CHECKPOINT_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/sentinai_checkpoint
RISK_ESCALATION_THRESHOLD=0.7
